class DarkEntity:
    def __init__(self, name, species, danger_level):
        self.__name = name
        self.__species = species
        self.__danger_level = danger_level

# Создаём объект
boss = DarkEntity("Балор", "Высший Демон", 99)

# Обходим защиту через name mangling
name = boss._DarkEntity__name
species = boss._DarkEntity__species
danger_level = boss._DarkEntity__danger_level

print(f"Данные из Гримуара: {name}, {species}, {danger_level}")
