class Inventory:
    def __init__(self, gold):
        self.__gold = gold

    def get_gold(self):
        return f"В кошеле: {self.__gold} проклятых монет"

    def change_gold(self, amount):
        new_balance = self.__gold + amount
        if new_balance < 0:
            print("Недостаточно золота для сделки!")
        else:
            self.__gold = new_balance


bag = Inventory(50)
print(bag.get_gold())        #В кошеле: 50 проклятых монет

bag.change_gold(-30)         #Тратим 30
bag.change_gold(10)          #Находим 10
print(bag.get_gold())        #В кошеле: 30 проклятых монет

bag.change_gold(-100)        #Пытаемся потратить 100
print(bag.get_gold())        #В кошеле: 30 проклятых монет
